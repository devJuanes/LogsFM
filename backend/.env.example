# Environment variables for Radio Backend
# Copy this file to .env and fill in the values

# Database
DATABASE_URL=postgresql://radio:RadioPass123@localhost:5432/radio_db

# Icecast
ICECAST_URL=http://localhost:8000
ICECAST_ADMIN_PASSWORD=hackme
ICECAST_SOURCE_PASSWORD=hackme

# JWT Authentication
SECRET_KEY=change-this-to-a-secure-random-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Media
MEDIA_DIR=/var/lib/icecast2/media/
PLAYLIST_FILE=/var/lib/icecast2/playlist.txt
